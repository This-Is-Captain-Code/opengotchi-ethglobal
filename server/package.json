{
  "name": "opengotchi-ethglobal-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Independent MQTT app server relaying T-Deck <-> stackchan for the opengotchi-ethglobal demo, with per-device server-side wallets (chain TBD).",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "hash": "node src/identity.js",
    "setup-wallets": "node scripts/setup_wallets.mjs"
  },
  "dependencies": {
    "@dynamic-labs-wallet/core": "^1.0.38",
    "@dynamic-labs-wallet/node-evm": "^1.0.38",
    "@x402/evm": "^2.15.0",
    "@x402/fetch": "^2.15.0",
    "dotenv": "^16.4.5",
    "mqtt": "^5.10.1",
    "viem": "^2.21.0"
  },
  "engines": {
    "node": ">=20"
  }
}
