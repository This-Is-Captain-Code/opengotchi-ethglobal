# ── MQTT broker (public — we do not run our own) ──────────────────────────
BROKER_URL=mqtt://broker.emqx.io:1883

# ── Devices in the demo ───────────────────────────────────────────────────
# HASH is the device's gotchiOS identity (topic prefix og/d/<HASH>/...).
# NOTE: the T-Deck firmware (feat/tdeck-port) hashes differently than identity.js
# (raw MAC bytes + "captain-virgin-sarv-monk"); use the value from its serial log.
DEVICE_STACKCHAN_HASH=df1ca8bb8271ab6d751e6d520e1c8ec3
DEVICE_STACKCHAN_LABEL=stackchan
DEVICE_STACKCHAN_ENS=stackchan.captaincode.eth

DEVICE_TDECK_HASH=bbef70c6ced36f3e01a429fe8d49c29e
DEVICE_TDECK_LABEL=tdeck
DEVICE_TDECK_ENS=tdeck.captaincode.eth

# ── HTTP (Render sets PORT automatically) ─────────────────────────────────
PORT=8080

# ── ENS resolution (read-only) — mainnet ENS (real names, e.g. subnames of captaincode.eth) ──
ENS_CHAIN=mainnet
ENS_RPC_URL=https://ethereum-rpc.publicnode.com

# ── Server-side wallets ────────────────────────────────────────────────────
# none | mock | dynamic   (dynamic = real Base Sepolia transfers; Linux/macOS only)
WALLET_PROVIDER=mock
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Dynamic server wallets (when WALLET_PROVIDER=dynamic):
DYNAMIC_ENVIRONMENT_ID=
DYNAMIC_AUTH_TOKEN=
WALLET_PASSWORD=

# Created wallet creds. On ephemeral hosts (Render) set WALLETS_JSON to the blob
# printed by `npm run setup-wallets` so wallets survive redeploys.
WALLETS_JSON=
# First-boot helper: set to true once (with no creds) to auto-create wallets on
# startup and log the WALLETS_JSON to copy into the env var; then remove it.
AUTO_CREATE_WALLETS=
