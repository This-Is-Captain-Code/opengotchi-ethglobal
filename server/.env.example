# ── MQTT broker (public — we do not run our own) ──────────────────────────
BROKER_URL=mqtt://broker.emqx.io:1883

# ── Devices in the demo ───────────────────────────────────────────────────
# Each device is identified by its gotchiOS hash:
#   HASH = hex(SHA256("AA:BB:CC:DD:EE:FF" + "opengotchi-captain-virgin-sarv-monk"))[:32]
# Either set the hash directly, or set the MAC and let identity.js compute it.
# Run `npm run hash -- AA:BB:CC:DD:EE:FF` to compute a hash from a MAC.

# stackchan (M5 CoreS3) — known hash
DEVICE_STACKCHAN_HASH=df1ca8bb8271ab6d751e6d520e1c8ec3
DEVICE_STACKCHAN_LABEL=stackchan

# LilyGo T-Deck Plus — fill in (compute from its MAC or read from serial log)
DEVICE_TDECK_HASH=
DEVICE_TDECK_LABEL=tdeck

# ── HTTP ──────────────────────────────────────────────────────────────────
PORT=8080

# ── Server-side wallets (chain TBD — leave blank for the no-op provider) ───
# WALLET_PROVIDER=none | (future: evm)
WALLET_PROVIDER=none
# When an EVM chain is chosen later:
# WALLET_RPC_URL=
# WALLET_STACKCHAN_PK=
# WALLET_TDECK_PK=
